# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/freelanceflow?retryWrites=true&w=majority

# Authentication Secrets
JWT_SECRET=your_jwt_access_secret_key_change_me_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me_in_production

# Frontend Client URL
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer SMTP) Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# AI Integration (OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Google reCAPTCHA v2 Configuration
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
